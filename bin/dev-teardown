#!/usr/bin/env bash
# Remove local dev skill symlinks. Restores global ship as the active install.
set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$REPO_ROOT/.aria/skills"

if [ ! -d "$SKILLS_DIR" ]; then
  echo "Nothing to tear down — .aria/skills/ doesn't exist."
  exit 0
fi

# Remove individual skill symlinks
removed=()
for link in "$SKILLS_DIR"/*/; do
  name="$(basename "$link")"
  [ "$name" = "ship" ] && continue
  if [ -L "${link%/}" ]; then
    rm "${link%/}"
    removed+=("$name")
  fi
done

# Remove the ship symlink
if [ -L "$SKILLS_DIR/ship" ]; then
  rm "$SKILLS_DIR/ship"
  removed+=("ship")
fi

# Clean up empty dirs
rmdir "$SKILLS_DIR" 2>/dev/null || true
rmdir "$REPO_ROOT/.aria" 2>/dev/null || true

if [ ${#removed[@]} -gt 0 ]; then
  echo "Removed: ${removed[*]}"
else
  echo "No symlinks found."
fi
echo "Dev mode deactivated. Global ship (~/.aria/skills/ship) is now active."
